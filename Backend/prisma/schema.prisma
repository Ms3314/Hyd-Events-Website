// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  college   String
  about     String?   
  orgPic    String?  @default("https://cdn-cjhkj.nitrocdn.com/krXSsXVqwzhduXLVuGLToUwHLNnSxUxO/assets/images/optimized/rev-b135bb1/spotme.com/wp-content/uploads/2020/07/Hero-1.jpg")
  orgBanner String?  @default("https://cdn-cjhkj.nitrocdn.com/krXSsXVqwzhduXLVuGLToUwHLNnSxUxO/assets/images/optimized/rev-b135bb1/spotme.com/wp-content/uploads/2020/07/Hero-1.jpg")
  website   String?  @default("")
  instagram String?  @default("")
  events    Event[]  // One-to-many relationship
}

model Event {
  id                 Int           @id @default(autoincrement())
  title              String
  MaxSize            Int           @default(1)
  description        String
  location           String        @default("Online")
  deadline           DateTime      @default(dbgenerated("NOW() + interval '7 days'"))
  eventDate          DateTime
  price              Int           @default(0)
  registrationLink   String
  formLink           String        @default("https://cdn-cjhkj.nitrocdn.com/krXSsXVqwzhduXLVuGLToUwHLNnSxUxO/assets/images/optimized/rev-b135bb1/spotme.com/wp-content/uploads/2020/07/Hero-1.jpg")
  views              Int?
  formClicks         Int?
  eventImage         String?       @default("https://cdn-cjhkj.nitrocdn.com/krXSsXVqwzhduXLVuGLToUwHLNnSxUxO/assets/images/optimized/rev-b135bb1/spotme.com/wp-content/uploads/2020/07/Hero-1.jpg")      
  organizationId     Int           // Foreign key
  genre              String[]
  organization       Organization  @relation(fields: [organizationId], references: [id])
}




